<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #0f0f0f, #1a1a1a);
            font-family: Arial, sans-serif;
            color: white;
        }

        .cockpit-container {
            width: 100%;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(20px);
        }

        .panel {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 0 40px rgba(0,0,0,0.4);
            text-align: center;
        }

        h1 {
            font-size: 48px;
            margin-bottom: 20px;
            background: linear-gradient(90deg, #00d4ff, #0077ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body>
    <div class="cockpit-container">
        <div class="panel">
            <h1>MIDDO Cockpit</h1>
            <p>Interface premium prête pour l’intégration des modules IA.</p>
        </div>
    </div>
</body>
</html>
